{
  "Version": "2012-10-17",
  "Statement": [
    {
      "Sid": "SecretsManagerGetSecretValue",
      "Effect": "Allow",
      "Action": [
        "secretsmanager:GetSecretValue"
      ],
      "Resource": [
        "arn:aws:secretsmanager:ap-northeast-1:{{AWS_ACCOUNT_ID}}:secret:/oa-system/prod/*",
        "arn:aws:secretsmanager:ap-northeast-1:{{AWS_ACCOUNT_ID}}:secret:/oa-system/staging/*"
      ]
    },
    {
      "Sid": "KMSDecryptForSecrets",
      "Effect": "Allow",
      "Action": [
        "kms:Decrypt"
      ],
      "Resource": "arn:aws:kms:ap-northeast-1:{{AWS_ACCOUNT_ID}}:key/{{KMS_KEY_ID}}"
    },
    {
      "Sid": "CloudWatchLogsCreateLogGroup",
      "Effect": "Allow",
      "Action": [
        "logs:CreateLogGroup"
      ],
      "Resource": [
        "arn:aws:logs:ap-northeast-1:{{AWS_ACCOUNT_ID}}:log-group:/ecs/oa-system-prod",
        "arn:aws:logs:ap-northeast-1:{{AWS_ACCOUNT_ID}}:log-group:/ecs/oa-system-staging"
      ]
    }
  ]
}
