# ============================================================
# OA顧客管理システム — さくらのVPS 環境変数テンプレート
#
# このファイルをコピーして .env を作成してください。
#   cp .env.example .env
#   chmod 600 .env   # rootまたはdockerグループのみ読み取り可
#
# [必須] と書かれた項目はすべて設定してから起動してください。
# ============================================================

# ----------------------------------------------------------
# データベース接続 [必須]
# ----------------------------------------------------------
# 本番 (別VPS の PostgreSQL を使用する場合):
# ※ DB側で SSL を有効にしていない場合は ?sslmode=require を削除すること
DATABASE_URL=postgresql://oa_user:【DBパスワード】@【DB_VPS_IPアドレス】:5432/oadb?sslmode=require
#
# ローカル検証 (docker compose --profile local-db を使う場合):
# DATABASE_URL=postgresql://oa_user:oa_pass@postgres:5432/oadb

# ----------------------------------------------------------
# NextAuth.js [必須]
# ----------------------------------------------------------
# JWT 署名鍵: 必ず本番用にランダム生成すること
#   生成コマンド: openssl rand -base64 32
NEXTAUTH_SECRET=【openssl rand -base64 32 の出力】

# アプリケーションの公開URL (末尾スラッシュなし)
NEXTAUTH_URL=https://app.itf-oa.jp

# ----------------------------------------------------------
# アプリケーション設定
# ----------------------------------------------------------
# Node.js 動作モード (変更不要)
NODE_ENV=production

# アプリ環境識別子
#   production: 本番 (外部送信が許可される)
#   staging:    ステージング (DISABLE_* フラグが有効)
APP_ENV=production

# インフラ実装モード [重要]
#   local: LocalMailer / LocalQueue / LocalWebhook を使用
#          メール・Webhookはdry-run (ログのみ)。再起動でキューが消える。
#   smtp:  SMTPメール送信を有効化 (パスワード再設定メール等)
#          SMTP_* 環境変数の設定が必須
#   aws:   SES / SQS を使用 (VPSでは設定しないこと)
INFRASTRUCTURE_MODE=smtp

# ----------------------------------------------------------
# Outbox Poll 認証 [outbox自動実行を使う場合は必須]
# ----------------------------------------------------------
# outbox-poll.sh がログインに使用するプラットフォーム管理者の認証情報
# このユーザーは platform_admin ロールを持つ必要がある
# ※ 初回セットアップでは後述の「初期ユーザー作成」後に設定する
OUTBOX_POLL_LOGIN_ID=【platform_adminのログインID】
OUTBOX_POLL_PASSWORD=【platform_adminのパスワード】

# outbox-poll.sh がアプリにアクセスする URL
# Nginx 経由 (HTTPS) でも localhost 直アクセスでも可
APP_URL=https://app.itf-oa.jp

# ----------------------------------------------------------
# 障害通知 (オプション)
# ----------------------------------------------------------
# アウトボックスの dead イベント発生時の通知先
# OUTBOX_ALERT_WEBHOOK_URL=https://hooks.example.com/alert
# OUTBOX_ALERT_EMAIL_TO=ops@example.com

# ----------------------------------------------------------
# SMTP メール送信 [INFRASTRUCTURE_MODE=smtp の場合は必須]
# ----------------------------------------------------------
# パスワード再設定メール等の送信に使用
SMTP_HOST=itf-oa.sakura.ne.jp
SMTP_PORT=587
SMTP_USER=noreply@mail.itf-oa.jp
SMTP_PASSWORD=【SMTPパスワード（ECS: Secrets Manager / SSM 経由推奨）】
MAIL_FROM=noreply@mail.itf-oa.jp
