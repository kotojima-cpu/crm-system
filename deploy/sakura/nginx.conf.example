# ============================================================
# OA顧客管理システム — Nginx リバースプロキシ設定
#
# 配置先: /etc/nginx/sites-available/oa-system
# 有効化: sudo ln -s /etc/nginx/sites-available/oa-system \
#                    /etc/nginx/sites-enabled/oa-system
#         sudo nginx -t && sudo systemctl reload nginx
#
# 初回セットアップ手順:
#   1. このファイルをそのまま配置して nginx -t && systemctl reload nginx
#   2. sudo certbot --nginx -d app.itf-oa.com
#      → certbot が自動で HTTPS リダイレクト・証明書パス・SSL 設定を追記する
#   3. certbot 完了後、下記の「certbot 完了後に手動追加」セクションの
#      セキュリティヘッダーを HTTPS server ブロック内に追記する
# ============================================================

# HTTP — 初回は certbot がここを書き換えて HTTPS リダイレクトを追加する
server {
    listen 80;
    listen [::]:80;
    server_name app.itf-oa.com;

    # ----------------------------------------------------------
    # ログ
    # ----------------------------------------------------------
    access_log /var/log/nginx/oa-system-access.log;
    error_log  /var/log/nginx/oa-system-error.log;

    # ----------------------------------------------------------
    # アップロードサイズ上限 (必要に応じて調整)
    # ----------------------------------------------------------
    client_max_body_size 10m;

    # ----------------------------------------------------------
    # ヘルスチェック — ログ抑制
    # ----------------------------------------------------------
    location = /api/health {
        proxy_pass         http://127.0.0.1:3000;
        proxy_http_version 1.1;
        proxy_set_header   Host              $host;
        proxy_set_header   X-Real-IP         $remote_addr;
        proxy_set_header   X-Forwarded-For   $proxy_add_x_forwarded_for;
        proxy_set_header   X-Forwarded-Proto $scheme;
        proxy_read_timeout 10s;
        access_log off;
    }

    # ----------------------------------------------------------
    # Next.js 静的アセット (_next/static) — キャッシュ強化
    # ----------------------------------------------------------
    location /_next/static/ {
        proxy_pass         http://127.0.0.1:3000;
        proxy_http_version 1.1;
        proxy_set_header   Host              $host;
        proxy_set_header   X-Forwarded-For   $proxy_add_x_forwarded_for;
        proxy_set_header   X-Forwarded-Proto $scheme;
        expires            1y;
        add_header         Cache-Control "public, immutable";
    }

    # ----------------------------------------------------------
    # すべてのリクエストを Next.js アプリへ転送
    # ----------------------------------------------------------
    location / {
        proxy_pass         http://127.0.0.1:3000;
        proxy_http_version 1.1;

        # WebSocket 対応
        proxy_set_header   Upgrade           $http_upgrade;
        proxy_set_header   Connection        "upgrade";

        # プロキシヘッダー
        proxy_set_header   Host              $host;
        proxy_set_header   X-Real-IP         $remote_addr;
        proxy_set_header   X-Forwarded-For   $proxy_add_x_forwarded_for;
        proxy_set_header   X-Forwarded-Proto $scheme;

        # バッファ・タイムアウト
        proxy_buffering    off;
        proxy_read_timeout 60s;
    }
}

# ============================================================
# certbot 完了後に手動追加:
#
# certbot が生成した HTTPS server ブロック内に
# 以下のセキュリティヘッダーを追記してください。
#
#   add_header Strict-Transport-Security "max-age=63072000; includeSubDomains" always;
#   add_header X-Content-Type-Options    nosniff always;
#   add_header X-Frame-Options           SAMEORIGIN always;
#   add_header Referrer-Policy           "strict-origin-when-cross-origin" always;
#
# 追記後: sudo nginx -t && sudo systemctl reload nginx
# ============================================================
