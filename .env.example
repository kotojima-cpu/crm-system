# ==============================================
# OA顧客管理システム — 環境変数テンプレート
# ==============================================
# このファイルをコピーして .env を作成してください。
# .env はリポジトリにコミットしないでください。

# --- データベース ---
# ローカル開発: SQLite
DATABASE_URL="file:./dev.db"
# テスト環境 (Netlify staging): SQLite（ビルド時にDB作成・シード）
# DATABASE_URL="file:./dev.db"
# 本番環境 (PostgreSQL):
# DATABASE_URL="postgresql://user:password@host:5432/oa_crm?schema=public"

# --- NextAuth.js ---
# セッション署名用シークレット（必須、環境ごとに異なる値を使用）
NEXTAUTH_SECRET="your-secret-key-here"
# アプリケーションのベースURL
NEXTAUTH_URL="http://localhost:3000"

# --- アプリケーション ---
# 環境識別子: "development" | "staging" | "preview" | "production"
# Netlify では netlify.toml で自動設定される
# APP_ENV="development"
